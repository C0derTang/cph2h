# Neon Postgres (provisioned via Vercel Marketplace)
DATABASE_URL=

# Clerk (provisioned via Vercel Marketplace)
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=
CLERK_SECRET_KEY=

# LiveKit Cloud
LIVEKIT_URL=
LIVEKIT_API_KEY=
LIVEKIT_API_SECRET=
NEXT_PUBLIC_LIVEKIT_URL=

# Piston (code execution for sample-test runs, issue #46). Optional: defaults
# to the free, keyless public instance at https://emkc.org/api/v2/piston
# (rate-limited to ~5 req/s). Set only to point at a self-hosted instance.
PISTON_URL=

# Bearer token protecting /api/cron/* routes
CRON_SECRET=

# Stripe — tournament registration ($5 entry). Without these keys the register
# route degrades to a 503 and the page shows "registration isn't open yet".
# STRIPE_WEBHOOK_SECRET is the signing secret for /api/stripe/webhook
# (from `stripe listen` locally, or the Stripe dashboard webhook endpoint).
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# Discord invite for the tournament (public NEXT_PUBLIC_*). Falls back to "#".
NEXT_PUBLIC_DISCORD_URL=

# Set to 1 to enable /api/dev/inject-verdict for e2e testing (never in prod)
RACE_TEST_MODE=

# Playwright e2e smoke test (`pnpm test:e2e`, issue #18) — NOT part of CI.
# Base URL of the running app under test, plus two existing Clerk-instance
# user emails to sign in as. See e2e/race.spec.ts for the full requirements.
E2E_BASE_URL=
E2E_USER_A_EMAIL=
E2E_USER_B_EMAIL=
