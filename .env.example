# Neon Postgres (provisioned via Vercel Marketplace)
DATABASE_URL=

# Clerk (provisioned via Vercel Marketplace)
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=
CLERK_SECRET_KEY=

# LiveKit Cloud
LIVEKIT_URL=
LIVEKIT_API_KEY=
LIVEKIT_API_SECRET=
NEXT_PUBLIC_LIVEKIT_URL=

# Judge0 CE (RapidAPI key)
JUDGE0_API_KEY=

# 32-byte hex key for AES-256-GCM encryption of stored CF credentials
CF_CRED_KEY=

# Bearer token protecting /api/cron/* routes
CRON_SECRET=

# Set to 1 to enable /api/dev/inject-verdict for e2e testing (never in prod)
RACE_TEST_MODE=

# Playwright e2e smoke test (`pnpm test:e2e`, issue #18) — NOT part of CI.
# Base URL of the running app under test, plus two existing Clerk-instance
# user emails to sign in as. See e2e/race.spec.ts for the full requirements.
E2E_BASE_URL=
E2E_USER_A_EMAIL=
E2E_USER_B_EMAIL=
