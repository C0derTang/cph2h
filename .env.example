# Neon Postgres (provisioned via Vercel Marketplace)
DATABASE_URL=

# Clerk (provisioned via Vercel Marketplace)
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=
CLERK_SECRET_KEY=

# LiveKit Cloud (clients receive the URL from /api/livekit/token)
LIVEKIT_URL=
LIVEKIT_API_KEY=
LIVEKIT_API_SECRET=

# Codeforces OpenID Connect (register the app at codeforces.com/settings/api;
# redirect URIs must include <origin>/api/cf/oauth/callback for each env, e.g.
# http://localhost:3000/api/cf/oauth/callback and the prod domain equivalent)
CF_OAUTH_CLIENT_ID=
CF_OAUTH_CLIENT_SECRET=

# Bearer token protecting /api/cron/* routes
CRON_SECRET=

# Set to 1 to enable /api/dev/inject-verdict for e2e testing (never in prod)
RACE_TEST_MODE=

# Playwright e2e smoke test (`pnpm test:e2e`) — NOT part of CI.
# Base URL of the running app under test, plus two existing Clerk-instance
# user emails to sign in as. See e2e/race.spec.ts for the full requirements.
E2E_BASE_URL=
E2E_USER_A_EMAIL=
E2E_USER_B_EMAIL=
